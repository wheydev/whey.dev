---
import { SITE } from '../consts'
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer__inner">
    <span class="footer__copy">
      &copy; {year} WheyDev LLC &middot; Registered in Wyoming, USA
    </span>
    <div class="footer__links">
      <a href={SITE.twitter} target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" title="X">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
      <a href={SITE.operatorUrl} target="_blank" rel="noopener noreferrer" class="footer__operator">ederchristian.com</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    border-top: 0.5px solid var(--border-subtle);
    margin-top: 80px;
  }
  .footer__inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .footer__copy {
    font-size: 12px;
    color: var(--text-tertiary);
  }
  .footer__links {
    display: flex;
    align-items: center;
    gap: 16px;
    color: var(--text-tertiary);
  }
  .footer__links a {
    color: var(--text-tertiary);
    display: inline-flex;
    align-items: center;
    transition: color 150ms ease;
  }
  .footer__links a:hover { color: var(--text-primary); }
  .footer__operator {
    font-size: 12px;
  }
</style>
