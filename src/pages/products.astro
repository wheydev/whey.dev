---
import PageLayout from '../layouts/PageLayout.astro'
---

<PageLayout
  title="Products"
  description="Software products from WheyDev. Each one does a single thing well."
>
  <div class="container">
    <div class="page-header">
      <h1 class="page-title">Products</h1>
      <p class="page-subtitle">Each product does one thing well. Built in public, priced fairly, shipped by one engineer.</p>
    </div>

    <div class="products">
      <div class="product">
        <div class="product__header">
          <div class="product__emblem product__emblem--muted" aria-hidden="true">P</div>
          <div class="product__meta">
            <div class="product__name-row">
              <h2 class="product__name">Perspion</h2>
              <span class="badge badge--sunset">Sunset</span>
            </div>
            <span class="product__url product__url--muted">perspion.whey.dev</span>
          </div>
        </div>
        <p class="product__description">
          YouTube comment intelligence for creators who want signal, not noise. Shut down in July 2026 after a short run as an MVP — the lessons are written up in full.
        </p>
        <div class="product__tech">
          <span class="meta-tag">Next.js</span>
          <span class="meta-tag">TypeScript</span>
          <span class="meta-tag">Gemini</span>
          <span class="product__launched">Mar 2026 &ndash; Jul 2026</span>
        </div>
        <a href="/writing/perspion-post-mortem" class="btn btn--ghost">Read the post-mortem &rarr;</a>
      </div>

      <div class="product product--muted">
        <p class="product__coming">More coming. Follow the <a href="/changelog">changelog</a>.</p>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 24px;
  }
  .page-header {
    padding: 64px 0 48px;
    border-bottom: 0.5px solid var(--border-subtle);
    margin-bottom: 40px;
  }
  .page-title {
    font-size: 32px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .page-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0;
  }
  .products {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border-subtle);
    border: 0.5px solid var(--border-subtle);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 40px;
  }
  .product {
    background: var(--gray-1);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .product--muted { opacity: 0.5; }
  .product__header {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .product__emblem {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: var(--purple);
    color: #fff;
    font-size: 16px;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .product__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .product__name-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .product__name {
    font-size: 18px;
    font-weight: 500;
    margin: 0;
  }
  .product__url {
    font-size: 12px;
    color: var(--text-tertiary);
    transition: color 150ms ease;
  }
  .product__url:hover { color: var(--accent); }
  .product__description {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 560px;
  }
  .product__tech {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .product__coming {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
    padding: 8px 0;
  }
  .product__coming a {
    color: var(--accent);
  }
  .badge {
    display: inline-flex;
    align-items: center;
    height: 20px;
    padding: 0 8px;
    border-radius: 999px;
    font-size: 11px;
  }
  .badge--mvp {
    background: rgba(29, 216, 130, 0.12);
    border: 0.5px solid rgba(29, 216, 130, 0.4);
    color: var(--accent);
  }
  .badge--sunset {
    background: var(--gray-2);
    border: 0.5px solid var(--border-subtle);
    color: var(--text-tertiary);
  }
  .product__emblem--muted {
    background: var(--gray-3);
    color: var(--text-tertiary);
  }
  .product__url--muted {
    color: var(--text-tertiary);
    text-decoration: line-through;
  }
  .product__launched {
    font-size: 11px;
    color: var(--text-tertiary);
    padding: 2px 0;
  }
  .product__pricing-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .product__pricing {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-subtle);
    border: 0.5px solid var(--border-subtle);
    border-radius: 6px;
    overflow: hidden;
  }
  .pricing-plan {
    background: var(--gray-2);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .pricing-plan--pro { background: var(--gray-3); }
  .pricing-plan__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }
  .pricing-plan__name {
    font-size: 12px;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .pricing-plan__price {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }
  .pricing-plan__per {
    font-size: 11px;
    color: var(--text-tertiary);
    font-weight: 400;
  }
  .pricing-plan__desc {
    font-size: 11px;
    color: var(--text-tertiary);
    line-height: 1.4;
  }
  .meta-tag {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--gray-2);
    border: 0.5px solid var(--border-subtle);
    border-radius: 4px;
    padding: 2px 6px;
    font-family: var(--font-mono);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 150ms ease, border-color 150ms ease;
    border: 0.5px solid transparent;
    white-space: nowrap;
    width: fit-content;
  }
  .btn--primary {
    background: var(--accent);
    color: #000;
    border-color: var(--accent);
  }
  .btn--primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    color: #000;
  }
  .btn--ghost {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--border-subtle);
  }
  .btn--ghost:hover {
    color: var(--text-primary);
    border-color: var(--text-tertiary);
  }
  @media (max-width: 640px) {
    .product__pricing { grid-template-columns: 1fr; }
  }
</style>
