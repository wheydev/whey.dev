---
import PageLayout from '../layouts/PageLayout.astro'
import { getCollection } from 'astro:content'

const entries = await getCollection('changelog')
const sorted = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })
---

<PageLayout
  title="Changelog"
  description="A running log of what ships at WheyDev. Product updates, studio milestones, and open source releases."
>
  <div class="container">
    <div class="page-header">
      <h1 class="page-title">Changelog</h1>
      <p class="page-subtitle">Product updates and studio milestones, in order.</p>
      <a href="/rss.xml" class="rss-link" aria-label="RSS feed">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
        </svg>
        RSS
      </a>
    </div>

    <div class="changelog">
      {sorted.map(async (entry) => {
        const { Content } = await entry.render()
        return (
          <article class="entry" id={entry.slug}>
            <div class="entry__meta">
              <time class="entry__date" datetime={entry.data.date.toISOString()}>
                {formatDate(entry.data.date)}
              </time>
              {entry.data.product ? (
                <span class="entry__product">{entry.data.product}</span>
              ) : null}
              {entry.data.tags.map((tag: string) => (
                <span class="entry__tag">{tag}</span>
              ))}
            </div>
            <h2 class="entry__title">{entry.data.title}</h2>
            <p class="entry__description">{entry.data.description}</p>
            <div class="entry__body prose">
              <Content />
            </div>
          </article>
        )
      })}
    </div>
  </div>
</PageLayout>

<style>
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 24px;
  }
  .page-header {
    padding: 64px 0 48px;
    border-bottom: 0.5px solid var(--border-subtle);
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .page-title {
    font-size: 32px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .page-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0;
  }
  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 4px;
    transition: color 150ms ease;
    width: fit-content;
  }
  .rss-link:hover { color: var(--accent); }

  .changelog {
    display: flex;
    flex-direction: column;
  }
  .entry {
    padding: 40px 0;
    border-bottom: 0.5px solid var(--border-subtle);
  }
  .entry:last-child { border-bottom: none; }
  .entry__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .entry__date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
  }
  .entry__product {
    font-size: 11px;
    background: rgba(29, 216, 130, 0.12);
    border: 0.5px solid rgba(29, 216, 130, 0.4);
    color: var(--accent);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .entry__tag {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--gray-2);
    border: 0.5px solid var(--border-subtle);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .entry__title {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .entry__description {
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0 0 20px;
    line-height: 1.6;
  }
  .prose {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .prose p { margin: 0 0 12px; }
  .prose p:last-child { margin-bottom: 0; }
  .prose a { color: var(--accent); }
  .prose a:hover { color: var(--accent-hover); }
  .prose strong { color: var(--text-primary); font-weight: 500; }
</style>
