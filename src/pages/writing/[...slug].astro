---
import PageLayout from '../../layouts/PageLayout.astro'
import { getCollection, type CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const entries = await getCollection('writing', ({ data }) => !data.draft)
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

interface Props {
  entry: CollectionEntry<'writing'>
}

const { entry } = Astro.props
const { Content } = await entry.render()

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })
---

<PageLayout title={entry.data.title} description={entry.data.description}>
  <div class="container">
    <a href="/writing" class="back">&larr; Writing</a>

    <article class="post">
      <header class="post__header">
        <div class="post__meta">
          <time class="post__date" datetime={entry.data.date.toISOString()}>
            {formatDate(entry.data.date)}
          </time>
          {entry.data.product ? (
            <span class="post__product">{entry.data.product}</span>
          ) : null}
          {entry.data.tags.map((tag: string) => (
            <span class="post__tag">{tag}</span>
          ))}
        </div>
        <h1 class="post__title">{entry.data.title}</h1>
        <p class="post__description">{entry.data.description}</p>
      </header>

      <div class="post__body prose">
        <Content />
      </div>
    </article>
  </div>
</PageLayout>

<style>
  .container {
    max-width: var(--reading-width, 720px);
    margin: 0 auto;
    padding: 0 24px;
  }
  .back {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    color: var(--text-tertiary);
    margin-top: 48px;
    transition: color 150ms ease;
  }
  .back:hover { color: var(--accent); }

  .post__header {
    padding: 32px 0 32px;
    border-bottom: 0.5px solid var(--border-subtle);
    margin-bottom: 40px;
  }
  .post__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .post__date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
  }
  .post__product {
    font-size: 11px;
    background: rgba(29, 216, 130, 0.12);
    border: 0.5px solid rgba(29, 216, 130, 0.4);
    color: var(--accent);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .post__tag {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--gray-2);
    border: 0.5px solid var(--border-subtle);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .post__title {
    font-size: 32px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 12px;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .post__description {
    font-size: 16px;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .prose {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.8;
    padding-bottom: 24px;
  }
  .prose :global(p) { margin: 0 0 20px; }
  .prose :global(p:last-child) { margin-bottom: 0; }
  .prose :global(h2) {
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 40px 0 16px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .prose :global(h3) {
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 32px 0 12px;
  }
  .prose :global(a) { color: var(--accent); }
  .prose :global(a:hover) { color: var(--accent-hover); }
  .prose :global(strong) { color: var(--text-primary); font-weight: 500; }
  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 20px; padding-left: 22px; }
  .prose :global(li) { margin: 0 0 8px; }
  .prose :global(blockquote) {
    margin: 0 0 20px;
    padding: 4px 0 4px 20px;
    border-left: 2px solid var(--border-subtle);
    color: var(--text-tertiary);
  }
  .prose :global(hr) {
    border: none;
    border-top: 0.5px solid var(--border-subtle);
    margin: 40px 0;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--gray-2);
    border: 0.5px solid var(--border-subtle);
    border-radius: 4px;
    padding: 1px 5px;
  }
  .prose :global(pre) {
    background: var(--gray-1);
    border: 0.5px solid var(--border-subtle);
    border-radius: 8px;
    padding: 16px;
    overflow-x: auto;
    margin: 0 0 20px;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }
</style>
