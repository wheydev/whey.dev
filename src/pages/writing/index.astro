---
import PageLayout from '../../layouts/PageLayout.astro'
import { getCollection } from 'astro:content'

const entries = await getCollection('writing', ({ data }) => !data.draft)
const sorted = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })
---

<PageLayout
  title="Writing"
  description="Essays, post-mortems, and lessons from building products in public at WheyDev."
>
  <div class="container">
    <div class="page-header">
      <h1 class="page-title">Writing</h1>
      <p class="page-subtitle">Post-mortems and lessons from building in public.</p>
    </div>

    {sorted.length > 0 ? (
      <div class="posts">
        {sorted.map((entry) => (
          <a class="post" href={`/writing/${entry.slug}`}>
            <div class="post__meta">
              <time class="post__date" datetime={entry.data.date.toISOString()}>
                {formatDate(entry.data.date)}
              </time>
              {entry.data.product ? (
                <span class="post__product">{entry.data.product}</span>
              ) : null}
              {entry.data.tags.map((tag: string) => (
                <span class="post__tag">{tag}</span>
              ))}
            </div>
            <h2 class="post__title">{entry.data.title}</h2>
            <p class="post__description">{entry.data.description}</p>
            <span class="post__more">Read post &rarr;</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">Nothing published yet. Check back soon.</p>
    )}
  </div>
</PageLayout>

<style>
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 24px;
  }
  .page-header {
    padding: 64px 0 48px;
    border-bottom: 0.5px solid var(--border-subtle);
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .page-title {
    font-size: 32px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .page-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0;
  }

  .posts {
    display: flex;
    flex-direction: column;
  }
  .post {
    display: block;
    padding: 40px 0;
    border-bottom: 0.5px solid var(--border-subtle);
  }
  .post:last-child { border-bottom: none; }
  .post__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .post__date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
  }
  .post__product {
    font-size: 11px;
    background: rgba(29, 216, 130, 0.12);
    border: 0.5px solid rgba(29, 216, 130, 0.4);
    color: var(--accent);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .post__tag {
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--gray-2);
    border: 0.5px solid var(--border-subtle);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .post__title {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 8px;
    line-height: 1.3;
    transition: color 150ms ease;
  }
  .post:hover .post__title { color: var(--accent); }
  .post__description {
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0 0 16px;
    line-height: 1.6;
  }
  .post__more {
    font-size: 13px;
    color: var(--accent);
  }
  .empty {
    padding: 48px 0;
    font-size: 14px;
    color: var(--text-tertiary);
  }
</style>
